# -------------------------------------------------------
# Copy this file to .env.local and fill in the values
# -------------------------------------------------------
#
# --- Railway / production (minimum to sign in + use DB) ---
#   DATABASE_URL          → Reference Postgres on the web service
#   NEXTAUTH_SECRET       → openssl rand -base64 32  (required in prod)
#   NEXTAUTH_URL          → Exact public origin, e.g. https://xxx.up.railway.app
#   REDIS_URL             → Reference Redis (app + /api/health expect Redis)
#   MEILISEARCH_HOST      → Internal URL to your Meilisearch service + :7700
#   MEILISEARCH_API_KEY   → Same master key as Meilisearch container
# Optional: OPENLIBRARY_USER_AGENT (polite OL API use)
#
# Auth.js also accepts AUTH_SECRET / AUTH_URL (aliases for the NEXTAUTH_* vars).
# -------------------------------------------------------

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bookclub"

# Redis
REDIS_URL="redis://HOST:6379"

# Meilisearch
MEILISEARCH_HOST="http://HOST:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.com"

# Founding Member cutoff date (ISO 8601)
FOUNDING_MEMBER_CUTOFF_DATE="2025-12-31"

# Open Library
OPENLIBRARY_USER_AGENT="BookClub/1.0 (your@email.com)"

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Image uploads (reviews, feed, etc.) — S3-compatible. If unset, files are stored under public/uploads.
# Set S3_IMAGE_HOSTNAME (hostname only) so next.config can optimize remote images.
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=bookclub
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_IMAGE_HOSTNAME=

# Email (Resend)
RESEND_API_KEY=

# Giphy (GIF search in messages) — https://developers.giphy.com/dashboard/
GIPHY_API_KEY=
